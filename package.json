{
  "name": "ssg",
  "version": "1.0.0",
  "private": true,
  "description": "A personal static-site generator built in TypeScript.",
  "type": "commonjs",
  "scripts": {
    "build": "tsx src/cli.ts build",
    "dev": "tsx src/cli.ts dev",
    "build:watch": "tsx src/cli.ts dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('public', { recursive: true, force: true });\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rajp152k/ssg.git"
  },
  "keywords": [],
  "author": "Raj",
  "license": "MIT",
  "dependencies": {
    "marked": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.8.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "npm@11.6.0"
}
